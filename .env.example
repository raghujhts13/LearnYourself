# =============================================================================
# Shiroyaksha Learning Utility — Environment Variables
# Copy this file to .env.local and fill in the values you need.
# All variables are optional — only configure the providers you want to use.
# =============================================================================

# --- LLM Providers -----------------------------------------------------------
# Format: {PROVIDER}_API_KEY, {PROVIDER}_BASE_URL (optional), {PROVIDER}_MODELS (optional, comma-separated)

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODELS=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODELS=

# --- Ollama (Local Models) ---------------------------------------------------
# No API key needed. Configure BASE_URL here (server-side) so it bypasses SSRF
# protection automatically. Client-supplied localhost URLs are blocked in production.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODELS=llama3.3,llama3.2,qwen2.5,mistral,gemma3,hemma4

# --- TTS (Text-to-Speech) ----------------------------------------------------

TTS_OPENAI_API_KEY=
TTS_OPENAI_BASE_URL=

TTS_ELEVENLABS_API_KEY=
TTS_ELEVENLABS_BASE_URL=

# --- ASR (Automatic Speech Recognition) --------------------------------------
ASR_QWEN_API_KEY=
ASR_QWEN_BASE_URL=

# --- PDF Processing -----------------------------------------------------------

PDF_UNPDF_API_KEY=
PDF_UNPDF_BASE_URL=

PDF_MINERU_API_KEY=
PDF_MINERU_BASE_URL=

# --- Image Generation ---------------------------------------------------------

IMAGE_SEEDREAM_API_KEY=
IMAGE_SEEDREAM_BASE_URL=

IMAGE_NANO_BANANA_API_KEY=
IMAGE_NANO_BANANA_BASE_URL=

# --- Web Search ---------------------------------------------------------------

TAVILY_API_KEY=

# --- Proxy (optional) --------------------------------------------------------

# HTTP_PROXY=
# HTTPS_PROXY=

# --- Misc ---------------------------------------------------------------------

# Optional server-side default model for API routes like /api/generate-classroom
# Example: anthropic:claude-sonnet-4-6 or openai:gpt-4o
DEFAULT_MODEL=

# LOG_LEVEL=info
# LOG_FORMAT=pretty
# LLM_THINKING_DISABLED=false

# --- Local/Self-hosted Deployment ---------------------------------------------
# Set to "true" to allow private/local network URLs (e.g. localhost, 192.168.x.x).
# Required for self-hosted models like Ollama. Do NOT enable on public deployments.
# ALLOW_LOCAL_NETWORKS=true

# --- Classroom Sharing & Public URL ------------------------------------------
#
# When teachers click "Share", LYS stamps a public URL into the classroom
# JSON so visitors can load it from any browser. The URL is auto-detected in
# this priority order:
#   1. Active tunnel (TUNNEL_PROVIDER below)
#   2. PUBLIC_URL env var (explicit override — highest priority for static config)
#   3. Cloud platform env vars (Vercel VERCEL_URL, Railway RAILWAY_PUBLIC_DOMAIN,
#      Fly FLY_APP_NAME, Render RENDER_EXTERNAL_URL, Coolify APP_DOMAIN)
#   4. HTTP request origin (works for reverse-proxy / VPS, wrong for localhost)
#
# If you self-host on a VPS with a domain, just set PUBLIC_URL:
# PUBLIC_URL=https://classroom.yourschool.com
#
# If you run locally and want to share over the internet, enable a tunnel:

# TUNNEL_PROVIDER=none           # Options: none (default) | localtunnel | ngrok
# TUNNEL_PORT=3000               # Port Next.js listens on (default: 3000 or PORT)
# TUNNEL_SUBDOMAIN=myschool      # Optional fixed subdomain (provider-specific)

# For localtunnel (free, no account):
#   pnpm add localtunnel
#   TUNNEL_PROVIDER=localtunnel

# For ngrok (more stable, requires free account):
#   pnpm add @ngrok/ngrok
#   TUNNEL_PROVIDER=ngrok
#   NGROK_AUTHTOKEN=your_token_here   # From https://dashboard.ngrok.com/

# --- Deploy “Share via Vercel” (optional) -------------------------------------
# When teachers use Share → Vercel, this server runs `npx vercel deploy` with a
# staged copy of the project. Requires Node on the machine hosting LYS
# (typically local or a VPS), not inside a minimal serverless-only host.
# Create a token: https://vercel.com/account/tokens
#
# VERCEL_TOKEN=
